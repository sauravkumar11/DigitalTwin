# Copy this file to .env and fill in real values before running locally
# (Docker Compose sets most of these for you automatically.)

APP_NAME=TwinCare AI
ENV=development

# Security
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (Docker Compose default shown; adjust for local Postgres)
DATABASE_URL=postgresql://twincare:twincare@localhost:5432/twincare

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Google Gemini API - required for real AI-generated organ insights,
# report summarization, and meal-photo analysis. Without it, the app
# falls back to deterministic rule-based summaries so it still runs.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Uploads
UPLOAD_DIR=uploads

# CORS - comma-separated origins allowed to call this API
CORS_ORIGINS=["http://localhost:3000"]
